<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="user-card card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
      <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item card" bindtap="goToBookings">
      <text class="menu-icon">📅</text>
      <text class="menu-text">我的预定</text>
      <text class="arrow">›</text>
    </view>
    
    <view class="menu-item card" bindtap="bindPhone">
      <text class="menu-icon">📱</text>
      <text class="menu-text">绑定手机</text>
      <text class="arrow">›</text>
    </view>
    
    <view class="menu-item card" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout" wx:if="{{userInfo}}">退出登录</button>
</view>
