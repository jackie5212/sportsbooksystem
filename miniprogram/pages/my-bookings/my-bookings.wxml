<!--pages/my-bookings/my-bookings.wxml-->
<view class="container">
  <view class="tabs">
    <view 
      class="tab-item {{activeTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </view>

  <scroll-view scroll-y class="booking-list">
    <view class="booking-card card" wx:for="{{bookings}}" wx:key="id">
      <view class="booking-header">
        <text class="order-no">订单号: {{item.order_no}}</text>
        <text class="status status-{{item.status}}">{{item.status_text}}</text>
      </view>
      <view class="booking-body">
        <text class="court-name">{{item.court_name}}</text>
        <text class="booking-time">{{item.booking_date}} {{item.start_time}}-{{item.end_time}}</text>
        <text class="price">¥{{item.total_amount}}</text>
      </view>
      <view class="booking-footer">
        <button class="btn-detail" size="mini">查看详情</button>
        <button wx:if="{{item.status === 1}}" class="btn-cancel" size="mini">取消订单</button>
      </view>
    </view>

    <view class="empty-state" wx:if="{{bookings.length === 0}}">
      <text>暂无预定记录</text>
    </view>
  </scroll-view>
</view>
