/* pages/my-bookings/my-bookings.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #e0e0e0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  color: #07c160;
  border-bottom: 4rpx solid #07c160;
}

.booking-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.booking-card {
  margin-bottom: 20rpx;
}

.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-1 {
  background-color: #fff3e0;
  color: #ff9800;
}

.status-2 {
  background-color: #e8f5e9;
  color: #07c160;
}

.status-3 {
  background-color: #f5f5f5;
  color: #999;
}

.booking-body {
  margin-bottom: 20rpx;
}

.court-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.booking-time {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.booking-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-detail {
  background-color: #fff;
  color: #07c160;
  border: 1rpx solid #07c160;
}

.btn-cancel {
  background-color: #fff;
  color: #999;
  border: 1rpx solid #999;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
