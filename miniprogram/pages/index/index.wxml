<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-title">🎾 网球场地预定</view>
    <view class="header-subtitle">选择您喜欢的场地，开始运动吧！</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="🔍 搜索场地名称或位置"
      bindinput="onSearchInput"
      value="{{searchKeyword}}"
    />
  </view>

  <!-- 场地列表 -->
  <scroll-view 
    class="court-list" 
    scroll-y 
    bindscrolltolower="loadMore"
    lower-threshold="100"
  >
    <view 
      class="court-card" 
      wx:for="{{courts}}" 
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 场地图片 -->
      <view class="image-wrapper">
        <image class="court-image" src="{{item.images[0] || '/images/default-court.png'}}" mode="aspectFill"></image>
        <view class="rating-badge" wx:if="{{item.rating}}">
          <text class="star">⭐</text>
          <text class="rating-text">{{item.rating}}</text>
        </view>
      </view>
      
      <!-- 场地信息 -->
      <view class="court-info">
        <view class="info-header">
          <text class="court-name">{{item.name}}</text>
          <text class="court-location">📍 {{item.location}}</text>
        </view>
        
        <!-- 设施标签 -->
        <view class="facilities" wx:if="{{item.facilities && item.facilities.length > 0}}">
          <text class="facility-tag" wx:for="{{item.facilities}}" wx:key="*this" wx:for-item="facility">
            {{facility}}
          </text>
        </view>
        
        <!-- 价格和按钮 -->
        <view class="court-footer">
          <view class="price-section">
            <text class="price-symbol">¥</text>
            <text class="court-price">{{item.price_per_hour}}</text>
            <text class="price-unit">/小时</text>
          </view>
          <view class="book-btn">立即预定 →</view>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <view class="loading-tip" wx:if="{{!hasMore && courts.length > 0}}">
      <text>—— 没有更多了 ——</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && courts.length === 0}}">
      <view class="empty-icon">🎾</view>
      <text class="empty-text">暂无场地数据</text>
    </view>
  </scroll-view>
</view>
