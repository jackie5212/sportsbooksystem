/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #f5f5f5 100%);
}

/* 顶部标题栏 */
.header {
  padding: 40rpx 30rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.search-input:focus {
  background-color: #fff;
  border-color: #667eea;
}

.court-list {
  height: calc(100vh - 280rpx);
  padding: 20rpx 30rpx;
}

/* 场地卡片 */
.court-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.court-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

/* 图片区域 */
.image-wrapper {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.court-image {
  width: 100%;
  height: 100%;
}

.rating-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.star {
  font-size: 24rpx;
}

.rating-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #ff9500;
}

/* 场地信息 */
.court-info {
  padding: 24rpx;
}

.info-header {
  margin-bottom: 16rpx;
}

.court-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.court-location {
  font-size: 26rpx;
  color: #999;
  display: block;
}

/* 设施标签 */
.facilities {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.facility-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
  color: #0369a1;
  border-radius: 12rpx;
  font-size: 22rpx;
  border: 1rpx solid #bae6fd;
}

/* 底部价格和按钮 */
.court-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.court-price {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

.book-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.book-btn:active {
  opacity: 0.9;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
